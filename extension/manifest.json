{
  "manifest_version": 3,
  "name": "よう見とんで ヘルパー",
  "version": "1.0",
  "description": "note.comのセッションCookieをワンクリックでコピーする「よう見とんで」用の補助拡張機能",
  "permissions": ["cookies"],
  "host_permissions": ["https://note.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "よう見とんで ヘルパー",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
